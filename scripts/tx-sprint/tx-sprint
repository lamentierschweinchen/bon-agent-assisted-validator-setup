#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -n "${TX_SPRINT_PYTHON:-}" ]]; then
  PYTHON_BIN="${TX_SPRINT_PYTHON}"
elif [[ -x "${HOME}/.local/pipx/venvs/multiversx-sdk-cli/bin/python" ]]; then
  PYTHON_BIN="${HOME}/.local/pipx/venvs/multiversx-sdk-cli/bin/python"
else
  PYTHON_BIN="python3"
fi

exec "${PYTHON_BIN}" "${SCRIPT_DIR}/tx_sprint_harness.py" "$@"
